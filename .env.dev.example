# Conduit Lite — dev profile 환경 변수 예시
# 사용: cp .env.dev.example .env.dev (실 .env.dev는 .gitignore — 절대 커밋 금지)

# Express 부팅
PORT=3000
NODE_ENV=dev
LOG_LEVEL=debug

# DB (이슈 #3 Prisma에서 사용)
DATABASE_URL="file:./backend/prisma/dev.db"

# Frontend (이슈 #10에서 도입, VITE_ prefix는 client 노출)
VITE_API_URL=http://localhost:3000/api
VITE_APP_TITLE="Conduit Lite (dev)"
