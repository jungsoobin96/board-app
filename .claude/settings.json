{
  "permissions": {
    "allow": [
      "Read", "Glob", "Grep",
      "Agent(Explore)", "Agent(Plan)",
      "Agent(orchestrator)", "Agent(analyst)", "Agent(architect)",
      "Agent(developer)", "Agent(reviewer)", "Agent(deployer)",
      "Bash(npm run *)", "Bash(npx *)", "Bash(bun *)",
      "Bash(gradle *)", "Bash(./gradlew *)",
      "Bash(docker compose *)", "Bash(git *)", "Bash(gh *)",
      "Bash(mkdir *)", "Bash(ls *)",
      "Bash(bash .claude/scripts/*)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(git push --force)",
      "Bash(git reset --hard)",
      "Bash(cat .env*)",
      "Bash(echo $ANTHROPIC*)",
      "Bash(echo $API*)",
      "Bash(printenv)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'FILE=\"${CLAUDE_TOOL_INPUT_FILE_PATH:-${CLAUDE_TOOL_INPUT_file_path:-}}\"; if echo \"$FILE\" | grep -qiE \"(\\.env|\\.key|\\.pem|credentials|secret|api_key|apikey)\"; then echo \"BLOCKED: 보안 파일 수정 차단: $FILE\" >&2; exit 2; fi'"
          },
          {
            "type": "command",
            "command": "bash .claude/scripts/check-line-count.sh"
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/gate-precondition.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__devtoolkit-tasks__task_update",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[DevToolKit] Task status updated'"
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/update-flow-state.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/check-context-weight.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/scripts/check-phase-jump.sh"
          }
        ]
      }
    ]
  },
  "teammateMode": "tmux",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  }
}
