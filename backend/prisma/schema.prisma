// 본 schema는 Conduit Lite의 데이터 모델 정본 (08 §M11 BE-prisma, 07 HLD §3 인덱스 정합).
// R-F-07 (cascade 무결성)을 ON DELETE CASCADE로 schema-level 강제 — 서비스 레이어 의존 X.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 글 (Article) — 본문·제목·작성자·생성/수정 시각. 본문 길이 제한은 서비스 layer(M9 validators)에서 강제.
model Article {
  id        Int      @id @default(autoincrement())
  title     String
  body      String
  author    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comments    Comment[]
  articleTags ArticleTag[]

  // 목록 조회 R-N-01 (createdAt DESC + page/limit) 인덱스. 07 HLD §3 정합.
  @@index([createdAt(sort: Desc)])
}

// 댓글 (Comment) — 글에 종속. 글 삭제 시 cascade로 동시 삭제 (R-F-07).
model Comment {
  id        Int      @id @default(autoincrement())
  body      String
  author    String
  createdAt DateTime @default(now())

  articleId Int
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  // 댓글 목록 조회(글 단위 + 시간순) 인덱스. 07 HLD §3 정합.
  @@index([articleId, createdAt(sort: Desc)])
}

// 태그 (Tag) — name unique. 정규화는 서비스 layer(M7)에서 (lowercase + trim).
model Tag {
  id   Int    @id @default(autoincrement())
  name String @unique

  articleTags ArticleTag[]
}

// 글-태그 M-N 조인. 글 삭제 시 cascade. 태그 자체는 잔존(N-side cascade 미적용 — 태그는 다른 글에서 재사용).
model ArticleTag {
  articleId Int
  tagId     Int

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  // 복합 PK + 자동 인덱스 (07 HLD §3 ArticleTag(articleId,tagId) PK).
  @@id([articleId, tagId])
}
