{
  "name": "@app/backend",
  "version": "0.0.0",
  "private": true,
  "description": "Express + Prisma backend (Conduit Lite)",
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "dev": "dotenv -e ../.env.dev -- tsx watch src/server.ts",
    "dev:stg": "dotenv -e ../.env.stg -- tsx src/server.ts",
    "start": "dotenv -e ../.env.prod -- node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@app/shared": "workspace:*",
    "express": "^4.21.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/supertest": "^6.0.0",
    "dotenv-cli": "^7.4.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "vitest": "^2.1.0"
  }
}
