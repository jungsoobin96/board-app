# Conduit Lite — prod profile 환경 변수 예시
# 사용: cp .env.prod.example .env.prod (실 .env.prod는 .gitignore)
# 운영 환경에서는 시크릿 관리자(예: GitHub Secrets·Vault)를 사용하고 본 파일은 키 목록 참조용

PORT=3002
NODE_ENV=prod
LOG_LEVEL=warn

DATABASE_URL="file:./backend/prisma/prod.db"

# Frontend (이슈 #10) — prod는 same-origin reverse proxy 가정
VITE_API_URL=/api
VITE_APP_TITLE="Conduit Lite"
