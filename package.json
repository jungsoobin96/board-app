{
  "name": "board-app",
  "version": "0.0.0",
  "private": true,
  "description": "Conduit Lite — 학습용 게시판 풀스택 (글·댓글·태그 CRUD)",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc -b",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "smoke:dev": "pnpm --filter @app/backend exec dotenv -e ../.env.dev -- tsx ../scripts/smoke.ts dev",
    "smoke:stg": "pnpm --filter @app/backend exec dotenv -e ../.env.stg -- tsx ../scripts/smoke.ts stg",
    "smoke:prod": "pnpm --filter @app/backend exec dotenv -e ../.env.prod -- tsx ../scripts/smoke.ts prod",
    "smoke:3profiles": "pnpm run smoke:dev && pnpm run smoke:stg && pnpm run smoke:prod"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/node": "^20.17.0",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.16.0"
  }
}
